{
  "description": "Adds a browser action to toggle applying CSS to pages.",
  "manifest_version": 3,
  "name": "CSS Override",
  "version": "1.0",
  "homepage_url": "https://github.com/swcolegrove/css-override-web-extension",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/css16.png",
      "48": "icons/css48.png",
      "96": "icons/css96.png"
    },
    "default_popup": "popup/menu.html"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "48": "icons/css48.png",
    "96": "icons/css96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "css-override@scottco.co"
    }
  }
}
